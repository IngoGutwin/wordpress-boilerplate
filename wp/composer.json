{
  "version": "1.0.0",
  "name": "lone/wordpress_composer_starter",
  "description": "WordPress Composer Starter repository for quick-starting WordPress projects",
  "authors": [
    {
      "name": "IngoGutwin",
      "email": "onmabu@gmail.com"
    }
  ],
  "require": {
    "johnpbloch/wordpress": "6.7.2",
    "vlucas/phpdotenv": "^5.6",
    "wpackagist-plugin/wordpress-seo":"25.4",
    "vinkla/headache": "^3.5",
    "wpackagist-plugin/advanced-custom-fields": "6.4.2"
  },
  "config": {
    "allow-plugins": {
      "johnpbloch/wordpress-core-installer": true,
      "composer/installers": true
    }
  },
  "extra": {
    "wordpress-install-dir": "public/wordpress",
    "installer-paths": {
      "wp-content/plugins/{$name}/": ["type:wordpress-plugin"],
      "wp-content/themes/{$name}/": ["type:wordpress-theme"]
    }
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://wpackagist.org"
    },
    {
      "type": "path",
      "url": ""
    }
  ]

}
